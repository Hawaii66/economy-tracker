{
  "name": "economy-tracker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "convex:dev": "bash ./economy-tracker.sh dev convex dev",
    "convex:prod": "bash ./economy-tracker.sh prod convex dev",
    "convex:deploy:prod": "bash ./economy-tracker.sh prod convex deploy",
    "web:dev": "bash ./economy-tracker.sh dev web",
    "web:prod": "bash ./economy-tracker.sh prod web preview"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "dependencies": {
        "jose": "^6.2.3"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
